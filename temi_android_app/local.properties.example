# Copy this file to local.properties and fill in your local paths/server URLs.
#
# Windows example:
# sdk.dir=C\:\\Users\\YOUR_NAME\\AppData\\Local\\Android\\Sdk
#
# Android emulator can reach host machine with 10.0.2.2.
# Real temi/tablet should use a reachable LAN/Tailscale/public server URL.
FOUND_API_BASE_URL=http://10.0.2.2:8080
SEARCH_API_BASE_URL=http://10.0.2.2:8000
